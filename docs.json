{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gobi",
  "colors": {
    "primary": "#C4622D",
    "light": "#D4845A",
    "dark": "#A34E22"
  },
  "background": {
    "light": "#F9F8F7",
    "dark": "#202020"
  },
  "fonts": {
    "heading": {
      "family": "Tiempos Text",
      "source": "/fonts/TiemposText-Medium.woff2",
      "format": "woff2",
      "weight": 500
    },
    "body": {
      "family": "Graphik",
      "source": "/fonts/Graphik-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Help Center",
            "groups": [
              {
                "group": "Home",
                "pages": ["index"]
              },
              {
                "group": "Products",
                "pages": [
                  "products/desktop",
                  "products/space",
                  "products/cli",
                  "products/mobile"
                ]
              },
              {
                "group": "Reference",
                "pages": [
                  "introduction/faq",
                  "introduction/glossary"
                ]
              }
            ]
          },
          {
            "tab": "API & CLI",
            "groups": [
              {
                "group": "Coming soon",
                "pages": ["api/overview"]
              }
            ]
          },
          {
            "tab": "Changelog",
            "groups": [
              {
                "group": "Changelog",
                "pages": ["changelog/overview"]
              }
            ]
          },
          {
            "tab": "Policies & Documents",
            "groups": [
              {
                "group": "Legal",
                "pages": ["policies/overview"]
              }
            ]
          }
        ]
      },
      {
        "language": "ko",
        "tabs": [
          {
            "tab": "도움말 센터",
            "groups": [
              {
                "group": "홈",
                "pages": ["ko/index"]
              },
              {
                "group": "제품",
                "pages": [
                  "ko/products/desktop",
                  "ko/products/space",
                  "ko/products/cli",
                  "ko/products/mobile"
                ]
              },
              {
                "group": "참고 자료",
                "pages": [
                  "ko/introduction/faq",
                  "ko/introduction/glossary"
                ]
              }
            ]
          },
          {
            "tab": "API & CLI",
            "groups": [
              {
                "group": "곧 출시",
                "pages": ["ko/api/overview"]
              }
            ]
          },
          {
            "tab": "변경 로그",
            "groups": [
              {
                "group": "변경 로그",
                "pages": ["ko/changelog/overview"]
              }
            ]
          },
          {
            "tab": "정책 및 문서",
            "groups": [
              {
                "group": "법적 문서",
                "pages": ["ko/policies/overview"]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Support",
          "href": "mailto:support@joingobi.com",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {"type": "button", "label": "Get early access", "href": "https://gobihq.com"}
  },
  "footer": {
    "socials": {
      "x": "https://x.com/gobiai",
      "github": "https://github.com/gobi-ai"
    }
  }
}
