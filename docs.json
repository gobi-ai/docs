{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gobi",
  "colors": {
    "primary": "#C4622D",
    "light": "#D4845A",
    "dark": "#A34E22",
    "background": {
      "light": "#F9F8F7",
      "dark": "#383836"
    }
  },
  "fonts": {
    "heading": {"family": "Source Serif 4"},
    "body": {"family": "Inter"}
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Help Center",
        "groups": [
          {
            "group": "Home",
            "pages": ["index"]
          },
          {
            "group": "Products",
            "pages": [
              "products/desktop",
              "products/space",
              "products/cli",
              "products/mobile"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "introduction/faq",
              "introduction/glossary"
            ]
          }
        ]
      },
      {
        "tab": "API & CLI",
        "groups": [
          {
            "group": "Coming soon",
            "pages": ["api/overview"]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": ["changelog/overview"]
          }
        ]
      },
      {
        "tab": "Policies & Documents",
        "groups": [
          {
            "group": "Legal",
            "pages": ["policies/overview"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Support",
          "href": "mailto:support@joingobi.com",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {"type": "button", "label": "Get early access", "href": "https://gobihq.com"}
  },
  "footer": {
    "socials": {
      "x": "https://x.com/gobiai",
      "github": "https://github.com/gobi-ai"
    }
  }
}
