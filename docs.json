{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gobi",
  "colors": {
    "primary": "#C4622D",
    "light": "#D4845A",
    "dark": "#A34E22"
  },
  "fonts": {
    "heading": {"family": "Source Serif 4"},
    "body": {"family": "Inter"}
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Introduction",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "introduction/welcome",
              "introduction/what-is-pcm",
              "introduction/who-its-for",
              "introduction/ecosystem"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "introduction/faq",
              "introduction/glossary"
            ]
          }
        ]
      },
      {
        "tab": "Products",
        "groups": [
          {
            "group": "Products",
            "pages": [
              "products/desktop",
              "products/personal-space",
              "products/community-space",
              "products/cli",
              "products/mobile"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog/overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://gobihq.com",
          "icon": "house"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@joingobi.com",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [{"label": "Support", "href": "mailto:support@joingobi.com"}],
    "primary": {"type": "button", "label": "Get early access", "href": "https://gobihq.com"}
  },
  "footer": {
    "socials": {
      "x": "https://x.com/gobiai",
      "github": "https://github.com/gobi-ai"
    }
  }
}
